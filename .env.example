# GitLab Connection (sempre use https:// para gitlab.com)
VITE_GITLAB_URL=https://gitlab.com
VITE_GITLAB_GROUP_ID=your-group-id

# Proxy local (evita CORS no browser). Obrigatório para: npm run dev e npm run preview
VITE_USE_API_PROXY=true

# Authentication - Personal Access Token (Mode 1)
VITE_GITLAB_TOKEN=

# Authentication - OAuth2 (Mode 2)
VITE_GITLAB_CLIENT_ID=
VITE_GITLAB_REDIRECT_URI=
